diff --git a/techpack/datarmnet/core/Makefile b/techpack/datarmnet/core/Makefile
index ed85c84a4..d210510ff 100644
--- a/techpack/datarmnet/core/Makefile
+++ b/techpack/datarmnet/core/Makefile
@@ -3,11 +3,14 @@ KERNEL_SRC ?= /lib/modules/$(shell uname -r)/build
 KBUILD_OPTIONS := RMNET_CORE_ROOT=$(PWD)
 KBUILD_OPTIONS += MODNAME?=rmnet_core
 
+# This is the critical line to add the include path
+EXTRA_CFLAGS += -I$(src)
+
 all:
-	$(MAKE) -C $(KERNEL_SRC) M=$(shell pwd) modules $(KBUILD_OPTIONS)
+        $(MAKE) -C $(KERNEL_SRC) M=$(shell pwd) modules $(KBUILD_OPTIONS) EXTRA_CFLAGS="$(EXTRA_CFLAGS)"
 
 modules_install:
-	$(MAKE) INSTALL_MOD_STRIP=1 -C $(KERNEL_SRC) M=$(shell pwd) modules_install
+        $(MAKE) INSTALL_MOD_STRIP=1 -C $(KERNEL_SRC) M=$(shell pwd) modules_install
 
 clean:
-	$(MAKE) -C $(KERNEL_SRC) M=$(PWD) clean
+        $(MAKE) -C $(KERNEL_SRC) M=$(PWD) clean
